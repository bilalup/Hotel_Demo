# Leave blank for local dev — requests go to "/api" and Vite's dev-server proxy
# (see vite.config.js) forwards them to the backend on http://localhost:5000.
#
# For production, set this to your deployed backend's full API URL so the
# frontend talks to it directly (no proxy in prod). This is the ONLY thing
# you should need to change when deploying to a new environment:
# VITE_API_URL=https://api.yourhotel.com/api
VITE_API_URL=
