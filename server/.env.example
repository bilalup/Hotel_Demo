# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB - leave MONGODB_URI blank to auto-start a local in-memory MongoDB for dev.
# For production or persistent local dev, set a real connection string:
# MONGODB_URI=mongodb://127.0.0.1:27017/aurelia-hotel
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/aurelia-hotel
MONGODB_URI=

# Auth
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d

# Cloudinary (optional - image upload endpoint falls back to plain URLs if unset)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Seed script - demo admin user
ADMIN_NAME=Aurelia Admin
ADMIN_EMAIL=admin@aureliabay.com
ADMIN_PASSWORD=AureliaBay2026!
